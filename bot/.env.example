# Copy this file to ".env" and fill in your values. Never commit the real .env.

# Bot token from https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_TOKEN=your-bot-token-here

# Application (client) ID — Developer Portal -> your app -> General Information -> Application ID
CLIENT_ID=your-application-id-here

# Your Discord server (guild) ID — enable Developer Mode in Discord, right-click the server -> Copy Server ID.
# Used to register slash commands instantly to your one server.
GUILD_ID=your-server-id-here

# Comma-separated Discord ROLE IDs allowed to run admin sign-up commands
# (right-click a role -> Copy Role ID). Leave blank to allow anyone with the
# server "Manage Server" permission instead.
ADMIN_ROLE_IDS=
